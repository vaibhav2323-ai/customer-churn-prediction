# Backend-specific .env example — see root .env.example for full reference
ENVIRONMENT=development
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
REFRESH_SECRET_KEY=CHANGE_ME_different_secret_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=sqlite:///./churn.db
# Local dev:
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Production (Vercel → Render): CORS_ORIGINS=https://customer-churn-prediction-dun.vercel.app
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
# Local dev (HTTP):
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# Production cross-origin (Vercel → Render): COOKIE_SECURE=true  COOKIE_SAMESITE=none
