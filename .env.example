# ════════════════════════════════════════════════════════════════════════════
#  ChurnGuard — Environment Configuration
#  Copy to .env, fill in values, NEVER commit .env to git
# ════════════════════════════════════════════════════════════════════════════

# ── Runtime ──────────────────────────────────────────────────────────────────
# Set to "production" in prod; controls docs visibility, error verbosity, etc.
ENVIRONMENT=development

# ── JWT Secrets — generate with: openssl rand -hex 32 ────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
REFRESH_SECRET_KEY=CHANGE_ME_different_secret_generate_with_openssl_rand_hex_32

# ── Token lifetimes ───────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./churn.db
# For multi-instance production: use PostgreSQL instead:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/churnguard

# ── CORS — list your exact frontend origins, no wildcards ────────────────────
# Local dev:
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Production example:
# CORS_ORIGINS=https://app.yourdomain.com

# ── Cookie security ───────────────────────────────────────────────────────────
# Set COOKIE_SECURE=true in production (requires HTTPS)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── Brute-force protection ────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── Frontend Vite (local dev only — not used in Docker build) ─────────────────
VITE_API_URL=http://localhost:8000
